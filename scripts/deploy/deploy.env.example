BACKEND_PUBLIC_ORIGIN=https://api.example.com

# Vercel project linking
TRIAD_VERCEL_SCOPE=your-team-slug
TRIAD_WEB_VERCEL_PROJECT=triad-web
TRIAD_ADMIN_VERCEL_PROJECT=triad-admin
TRIAD_BUSINESS_VERCEL_PROJECT=triad-business

# Web build/runtime config
NEXT_PUBLIC_API_ORIGIN=https://api.example.com
BUSINESS_PUBLIC_API_ORIGIN=https://api.example.com
SITE_PUBLIC_TRIAD_WEB_APP_URL=https://app.example.com
SITE_PUBLIC_TRIAD_BUSINESS_APP_URL=https://business.example.com
SITE_PUBLIC_APP_STORE_URL=
SITE_PUBLIC_GOOGLE_PLAY_URL=
SITE_PUBLIC_CONTACT_EMAIL=hello@example.com

# Admin rewrite target
ADMIN_API_ORIGIN=https://api.example.com

# Backend image publishing
BACKEND_IMAGE_REPO=ghcr.io/your-org/triad-api
BACKEND_IMAGE_TAG=
BACKEND_IMAGE_LATEST_TAG=latest
BACKEND_DOCKER_PLATFORM=linux/amd64

# Marketing site image publishing
SITE_IMAGE_REPO=ghcr.io/your-org/triad-site
SITE_IMAGE_TAG=
SITE_IMAGE_LATEST_TAG=latest
SITE_DOCKER_PLATFORM=linux/amd64

# Example release hook:
# BACKEND_RELEASE_COMMAND=ssh deploy@api-host.example.com "docker pull $TRIAD_BACKEND_IMAGE && docker compose -f /srv/triad/docker-compose.yml up -d api"
BACKEND_RELEASE_COMMAND=

# Example release hook:
# SITE_RELEASE_COMMAND=ssh deploy@site-host.example.com "docker pull $TRIAD_SITE_IMAGE && docker compose -f /srv/triad/docker-compose.yml up -d triad-site"
SITE_RELEASE_COMMAND=

# Android app build/sign (./scripts/deploy/android-app.sh)
# Backend origin baked into BuildConfig.API_BASE_URL. Falls back to BACKEND_PUBLIC_ORIGIN.
ANDROID_API_BASE_URL=
# debug | release — release requires the keystore values below.
ANDROID_VARIANT=release
# Where the script copies app-release.apk and app-release.aab.
ANDROID_OUTPUT_DIR=dist/android
# 1 to skip the APK and only build the Play AAB.
ANDROID_BUNDLE_ONLY=0
# Absolute path to a JKS or PKCS12 keystore. Required for signed release.
ANDROID_KEYSTORE=
ANDROID_KEY_ALIAS=
ANDROID_KEYSTORE_PASSWORD=
# Defaults to ANDROID_KEYSTORE_PASSWORD when empty.
ANDROID_KEY_PASSWORD=
# Optional release hook. Receives TRIAD_ANDROID_APK, TRIAD_ANDROID_AAB,
# and TRIAD_ANDROID_VARIANT in its environment. Use it to upload to Play
# Console (e.g. fastlane supply), Firebase App Distribution, etc.
# Example:
# ANDROID_RELEASE_COMMAND=fastlane supply --aab "$TRIAD_ANDROID_AAB" --track internal --skip_upload_metadata --skip_upload_changelogs --skip_upload_images
ANDROID_RELEASE_COMMAND=
