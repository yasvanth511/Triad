{
  "ConnectionStrings": {
    // SECURITY: Never commit real credentials here.
    // Set via environment variable: ConnectionStrings__DefaultConnection
    // or Docker secret / Azure Key Vault / AWS Secrets Manager at runtime.
    "DefaultConnection": ""
  },
  "Jwt": {
    // SECURITY: Must be >= 32 cryptographically-random characters.
    // Set via environment variable: Jwt__Key (never hard-code in source).
    // Generate with: openssl rand -base64 48
    "Key": "",
    "Issuer": "ThirdWheel.API",
    "Audience": "ThirdWheel.IOSNative"
  },
  "Cors": {
    // Comma-separated list of allowed origins. Wildcards are not permitted in production.
    // Set via environment variable: Cors__AllowedOrigins
    "AllowedOrigins": "https://your-client-origin"
  },
  "Verification": {
    "Methods": {
      "live_verified": {
        "Enabled": true,
        "DisplayName": "Live Verified",
        "Version": "2026-04-23",
        "Provider": "mock_live_vendor",
        "ExpiresAfterDays": 365,
        "Settings": {
          "mode": "mock"
        }
      },
      "age_verified": {
        "Enabled": true,
        "DisplayName": "Age Verified",
        "Version": "2026-04-23",
        "Provider": "mock_age_vendor",
        "ExpiresAfterDays": 365,
        "Settings": {
          "mode": "mock"
        }
      },
      "phone_verified": {
        "Enabled": true,
        "DisplayName": "Phone Verified",
        "Version": "2026-04-23",
        "Provider": "mock_phone_vendor",
        "Settings": {
          "mode": "mock"
        }
      },
      "couple_verified": {
        "Enabled": true,
        "DisplayName": "Couple Verified",
        "Version": "2026-04-23",
        "Provider": "mock_couple_vendor",
        "Settings": {
          "mode": "mock"
        }
      },
      "partner_consent_verified": {
        "Enabled": true,
        "DisplayName": "Partner Consent Verified",
        "Version": "2026-04-23",
        "Provider": "partner_consent",
        "Settings": {
          "mode": "manual"
        }
      },
      "intent_verified": {
        "Enabled": true,
        "DisplayName": "Intent Verified",
        "Version": "2026-04-23",
        "Provider": "intent_verification",
        "Settings": {
          "mode": "manual"
        }
      },
      "in_person_verified": {
        "Enabled": true,
        "DisplayName": "In-Person Verified",
        "Version": "2026-04-23",
        "Provider": "event_verification",
        "Settings": {
          "mode": "manual"
        }
      },
      "social_verified": {
        "Enabled": true,
        "DisplayName": "Social Verified",
        "Version": "2026-04-23",
        "Provider": "social_verification",
        "Settings": {
          "mode": "manual",
          "approvedProviders": "instagram"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
